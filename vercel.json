{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "ledix9.vercel.app"
        }
      ],
      "destination": "https://www.ledix9.com/$1",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(iPhone|iPod|Android|BlackBerry|webOS|IEMobile|Opera Mini).*"
        }
      ],
      "missing": [
        {
          "type": "query",
          "key": "desktop"
        }
      ],
      "destination": "/phone/index.html",
      "permanent": false
    },
    {
      "source": "/index.html",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(iPhone|iPod|Android|BlackBerry|webOS|IEMobile|Opera Mini).*"
        }
      ],
      "missing": [
        {
          "type": "query",
          "key": "desktop"
        }
      ],
      "destination": "/phone/index.html",
      "permanent": false
    },
